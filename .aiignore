# Paths AI agents should NOT read into context (noise / generated / large / secret).
# Mirrors .gitignore plus agent-specific noise. See AGENTS.md §6 and docs/ai/REPO_MAP.md.

# Dependencies & lockfiles
node_modules/
jspm_packages/
package-lock.json

# Version control internals
.git/

# Build / coverage / cache
coverage/
.nyc_output/
dist/
build/

# Runtime state (generated)
data/                 # P1 persistence JSON snapshots
night-queue/          # local-only overnight task queue
*.log
npm-debug.log*

# Generated artifacts (rebuild with `npm run codex:generate` / the test suites)
plan/CODEX.md
plan/codex.json
plan/monitoring_report.json
browser_recordings/
plan/archive/         # historical ledgers; read only when investigating history

# Secrets & local env (never read; use .env.example for the schema)
.env
.env.*
*.env

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local agent/tool state
.claude/

# Binary / media (none expected in src, but skip if added)
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.zip
*.gz
