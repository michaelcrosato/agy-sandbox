# EditorConfig — consistent whitespace across editors and agents.
# https://editorconfig.org  (matches Prettier: 2-space indent, LF, final newline)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Preserve Markdown hard line breaks (two trailing spaces).
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2
