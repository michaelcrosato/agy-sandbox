# Copy to .env (gitignored) and fill in as needed. All values below are SAFE PLACEHOLDERS.
# Never commit real secrets. .env, .env.*, and *.env are gitignored.

# ── Game server (src/server.js) ───────────────────────────────────────────────
# HTTP + WebSocket port for the authoritative game server.
PORT=8080
# Directory for P1 persistence snapshots (galaxy + players). Gitignored.
PERSISTENCE_DIR=./data
# Galaxy/player autosave cadence in milliseconds.
AUTOSAVE_INTERVAL_MS=30000
# "production" disables the localtunnel public link; "test" is used by the suite.
NODE_ENV=development

# ── GitHub Actions autonomous coder (scripts/run-agent.js) ────────────────────
# Only needed when running the issue-triggered agent locally; CI injects these.
# Google Generative AI key used by the issue agent.
GEMINI_API_KEY=your-gemini-api-key-here
# GitHub token with repo scope (CI provides ${{ secrets.GITHUB_TOKEN }}).
GITHUB_TOKEN=your-github-token-here
# owner/repo slug the agent operates on.
GITHUB_REPOSITORY=your-org/agy-sandbox
# Issue number the agent should implement (set per run).
ISSUE_NUMBER=
