# Copy to .env (gitignored) and fill in as needed. All values below are SAFE PLACEHOLDERS.
# Never commit real secrets. .env, .env.*, and *.env are gitignored.
# Every variable is optional — the server boots with sensible defaults.

# ── Game server (src/server.js) ───────────────────────────────────────────────
# HTTP + WebSocket port for the authoritative game server.
PORT=8080
# "production" | "development" | "test". Tests set this automatically.
NODE_ENV=development
# Logger verbosity: debug | info | warn | error (src/net/logger.js).
LOG_LEVEL=info
# Directory for JSON persistence snapshots (galaxy + players). Gitignored.
PERSISTENCE_DIR=./data
# Galaxy/player autosave cadence in milliseconds.
AUTOSAVE_INTERVAL_MS=30000

# ── Networking & protocol feature flags (src/net/) ────────────────────────────
# Area-of-interest filtering of world broadcasts: "1" (default) or "0".
INTEREST_MANAGEMENT=1
# Interest radius in world units (default 3000).
INTEREST_RADIUS=3000
# Binary world-state protocol: "1" (default) or "0" for JSON.
BINARY_PROTOCOL=1
# Per-message deflate WebSocket compression: "1" to enable (default off).
WS_COMPRESSION=0
# Comma-separated Origin allowlist for WebSocket upgrades (empty = allow all).
ALLOWED_ORIGINS=
# Trust X-Forwarded-For (set only when behind a known reverse proxy): "1" to enable.
TRUST_PROXY=0
# Bearer token required for remote calls to /api/sandbox/* and /api/firewall/rules.
# Unset = those endpoints accept loopback callers only. Set a strong value when exposing publicly.
ADMIN_TOKEN=

# ── Scaling (optional; single process is the default) ─────────────────────────
# Number of sharded worker processes. >1 enables cluster/supervisor mode.
WORKERS=1
# Shard index — assigned automatically by the supervisor; set only for manual runs.
SHARD_INDEX=0
# Redis connection string. Unset = JSON file store + in-memory pub/sub.
REDIS_URL=
# "1" to also route cross-worker traffic through Redis pub/sub.
REDIS_SCALE_OUT=0

# ── Outbound API governance (src/net/ApiRateLimiter.js) ───────────────────────
# Sliding-window caps for outbound API calls made by sandboxed automation.
API_LIMIT_MINUTE=5
API_LIMIT_HOUR=100

# ── Guest-runner sandbox (src/net/GuestRunner*.js; local admin tooling) ───────
# Path of the guest script the runner executes.
GUEST_SCRIPT_PATH=
# Working directory the sandboxed guest is confined to.
GUEST_SANDBOX_DIR=
# Comma-separated DNS egress allowlist for guests.
GUEST_DNS_ALLOWLIST=
# Comma-separated SHA-256 allowlist of importable module hashes.
GUEST_ALLOWED_MODULE_HASHES=
# Shared secrets for the guest-runner admin API (set real values in .env only).
GUEST_HMAC_KEY=change-me
GUEST_RUN_TOKEN=change-me
# Where the sandbox security ledger is written (default plan/security_audit.json).
SECURITY_AUDIT_FILE=

# ── Stress tooling (scripts/agent/stress-test.js) ─────────────────────────────
STRESS_CONNS=50
STRESS_PORT=8080
STRESS_DURATION=10000

# ── GitHub Actions autonomous coder (scripts/run-agent.js) ────────────────────
# Only needed when running the issue-triggered agent locally; CI injects these.
GEMINI_API_KEY=your-gemini-api-key-here
# Optional model override for the issue agent.
GEMINI_MODEL=
# GitHub token with repo scope (CI provides ${{ secrets.GITHUB_TOKEN }}).
GITHUB_TOKEN=your-github-token-here
# owner/repo slug the agent operates on.
GITHUB_REPOSITORY=your-org/agy-sandbox
# Issue number the agent should implement (set per run).
ISSUE_NUMBER=
