{
  "name": "agy-sandbox",
  "version": "1.0.0",
  "description": "Starfall: Living Galaxy — browser-native multiplayer space sim with an autonomous-engineering harness",
  "private": true,
  "main": "src/server.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelcrosato/agy-sandbox.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "http-server .",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:client": "vitest run --project jsdom",
    "test:client:browser": "vitest run --project browser",
    "lint": "eslint src scripts",
    "format": "prettier --write \"src/**/*.{js,json}\" \"scripts/**/*.js\" \".github/**/*.md\" README.md",
    "format:check": "prettier --check \"src/**/*.{js,json}\" \"scripts/**/*.js\" \".github/**/*.md\" README.md",
    "typecheck": "tsc --noEmit",
    "agent:bootstrap": "npm ci",
    "codex:generate": "node scripts/agent/generate-codex.js",
    "cluster:smoke": "node scripts/agent/cluster-smoke.js",
    "benchmark:cluster": "node scripts/agent/cluster-benchmark.js",
    "agent:verify-substrate": "node scripts/agent/verify-substrate.mjs",
    "agent:check:core": "npm run agent:verify-substrate && npm run format:check && npm run lint && npm run typecheck && npm run build && npm test",
    "agent:check": "npm run codex:generate && npm run agent:check:core"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/genai": "^2.7.0",
    "@types/node": "^25.9.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
