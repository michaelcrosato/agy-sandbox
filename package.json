{
  "name": "agy-sandbox",
  "version": "1.0.0",
  "description": "Sandbox configured for maximum fully autonomous coding",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "http-server .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:client": "vitest run",
    "test:client:browser": "vitest run -c vitest.browser.config.js",
    "lint": "eslint src scripts",
    "format": "prettier --write \"src/**/*.{js,json}\" \"scripts/**/*.js\" \".github/**/*.md\" README.md",
    "format:check": "prettier --check \"src/**/*.{js,json}\" \"scripts/**/*.js\" \".github/**/*.md\" README.md",
    "typecheck": "tsc --noEmit",
    "agent:bootstrap": "npm ci",
    "codex:generate": "node scripts/agent/generate-codex.js",
    "cluster:smoke": "node scripts/agent/cluster-smoke.js",
    "benchmark:cluster": "node scripts/agent/cluster-benchmark.js",
    "agent:check": "npm run codex:generate && npm run format:check && npm run lint && npm run typecheck && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/genai": "^2.7.0",
    "@types/node": "^25.9.1",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
